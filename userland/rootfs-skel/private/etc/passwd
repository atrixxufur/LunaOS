# /etc/passwd — LunaOS user accounts
# Format: name:password:uid:gid:gecos:home:shell
#
# Passwords are in /etc/master.passwd (shadowed). '*' here = no direct login.
root:*:0:0:System Administrator:/var/root:/bin/bash
daemon:*:1:1:System Daemon:/var/root:/usr/bin/false
nobody:*:99:99:Unprivileged User:/var/empty:/usr/bin/false
lunaos:*:501:501:LunaOS User:/Users/lunaos:/bin/bash
