<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  SystemVersion.plist — LunaOS OS identification
  Location: /System/Library/CoreServices/SystemVersion.plist

  This file is read by:
   - sw_vers command
   - Gestalt() API (kSystemVersionMajor etc.)
   - Many third-party apps to determine OS version
   - XNU itself to set kern.osproductversion sysctl
-->
<plist version="1.0">
<dict>
    <key>ProductBuildVersion</key>
    <string>26A0001</string>

    <key>ProductCopyright</key>
    <string>2026 LunaOS Project. Portions Copyright Apple Inc.</string>

    <key>ProductName</key>
    <string>LunaOS</string>

    <key>ProductUserVisibleVersion</key>
    <string>0.1.0</string>

    <key>ProductVersion</key>
    <string>0.1.0</string>

    <!--
      iOSSupportVersion: not applicable, but some tools expect it.
      Set to match Darwin 26 era.
    -->
    <key>iOSSupportVersion</key>
    <string>19.0</string>
</dict>
</plist>
