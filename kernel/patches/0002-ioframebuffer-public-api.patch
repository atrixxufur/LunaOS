From: LunaOS Project <lunaos@puredarwin.org>
Date: 2026-02-28
Subject: [PATCH] iokit/graphics: expose IOFramebuffer VBL notification for IODRMShim

IODRMShim.kext registers a VBL (vertical blank) notification callback
via IOFramebuffer::addFramebufferNotification(). On stock XNU, this API
is only available to Apple-internal callers. This patch promotes it to
the public IOKit KPI so third-party KEXTs (like our IODRMShim) can use it
without the kpi.unsupported linkage.

Also exports IOFramebuffer::getVRAMRange() to the public KPI so
IODRMShim can map VRAM for CPU blits.
---
diff --git a/iokit/Families/IOGraphics/IOFramebuffer.cpp b/iokit/Families/IOGraphics/IOFramebuffer.cpp
--- a/iokit/Families/IOGraphics/IOFramebuffer.cpp
+++ b/iokit/Families/IOGraphics/IOFramebuffer.cpp
@@ -1,3 +1,10 @@
+/*
+ * LunaOS patch: promote addFramebufferNotification and getVRAMRange
+ * from unsupported KPI to iokit KPI.
+ *
+ * This allows IODRMShim.kext to use OSBundleLibraries: com.apple.kpi.iokit
+ * instead of com.apple.kpi.unsupported, making the KEXT more portable.
+ */
+
 #include <IOKit/graphics/IOFramebuffer.h>
 #include <IOKit/graphics/IOGraphicsPrivate.h>

@@ -245,7 +252,7 @@ IOReturn IOFramebuffer::addFramebufferNotification(
         IOFramebufferNotificationHandler handler,
         OSObject *self, void *ref,
         IOSelect event, UInt32 priority)
-__attribute__((visibility("hidden")))  /* was: internal only */
+__attribute__((visibility("default"))) /* LunaOS: promote to public KPI */
 {
     /* ... existing implementation unchanged ... */
 }

@@ -310,7 +317,7 @@ IOReturn IOFramebuffer::addFramebufferNotification(
 IODeviceMemory * IOFramebuffer::getVRAMRange()
-__attribute__((visibility("hidden")))
+__attribute__((visibility("default"))) /* LunaOS: promote to public KPI */
 {
     return vramRange;
 }

diff --git a/iokit/Families/IOGraphics/IOFramebuffer.exports b/iokit/Families/IOGraphics/IOFramebuffer.exports
--- a/iokit/Families/IOGraphics/IOFramebuffer.exports
+++ b/iokit/Families/IOGraphics/IOFramebuffer.exports
@@ -10,3 +10,7 @@
 _IOFramebuffer::setDisplayMode
 _IOFramebuffer::getCurrentDisplayMode
 _IOFramebuffer::getDisplayModeCount
+# LunaOS additions — needed by IODRMShim.kext
+_IOFramebuffer::addFramebufferNotification
+_IOFramebuffer::getVRAMRange
+_IOFramebuffer::getPixelInformation
