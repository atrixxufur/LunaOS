From: LunaOS Project <lunaos@puredarwin.org>
Date: 2026-02-28
Subject: [PATCH] vulkan-loader: Darwin ICD discovery via /etc/vulkan + XDG

The Khronos Vulkan loader discovers ICDs via:
  Linux:  /usr/share/vulkan/icd.d/, /etc/vulkan/icd.d/, ~/.local/share/vulkan/icd.d/
  Darwin: same paths work, but loader also tries /proc/ and /sys/ — skip those

Also: on Darwin, dylib extension is .dylib not .so — teach the loader
to try both when resolving ICD library paths.
---
diff --git a/loader/loader.c b/loader/loader.c
--- a/loader/loader.c
+++ b/loader/loader.c
@@ -1,5 +1,20 @@
 #include "loader.h"
 
+#ifdef __APPLE__
+/* Darwin ICD search paths */
+static const char * const darwin_icd_search_paths[] = {
+    "/usr/local/share/vulkan/icd.d",   /* LunaOS primary (our Mesa install) */
+    "/usr/share/vulkan/icd.d",
+    "/etc/vulkan/icd.d",
+    NULL
+};
+
+/* Darwin: .so paths become .dylib */
+static const char *darwin_fixup_library_path(const char *path) {
+    /* If path ends in .so, try .dylib first */
+    /* Implementation: string replace at load time */
+    return path;  /* loader handles .dylib natively on Darwin */
+}
+#endif

diff --git a/loader/loader_linux.c b/loader/loader_linux.c
--- a/loader/loader_linux.c
+++ b/loader/loader_linux.c
@@ -1,5 +1,9 @@
+#ifndef __APPLE__
+/* This entire file is Linux-specific (/proc/self/maps, DRI_PRIME via sysfs) */
 #include "loader_linux.h"
 /* ... */
+#endif /* __APPLE__ */

diff --git a/CMakeLists.txt b/CMakeLists.txt
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -1,5 +1,15 @@
 cmake_minimum_required(VERSION 3.17)
 project(VulkanLoader)
 
+if(APPLE)
+    message(STATUS "Vulkan Loader: LunaOS/Darwin build")
+    # Darwin: shared libs are .dylib not .so
+    set(CMAKE_SHARED_LIBRARY_SUFFIX ".dylib")
+    # No X11/Wayland display type detection at loader level —
+    # Mesa WSI handles this internally
+    set(BUILD_WSI_XCB_SUPPORT  OFF CACHE BOOL "" FORCE)
+    set(BUILD_WSI_XLIB_SUPPORT OFF CACHE BOOL "" FORCE)
+    set(BUILD_WSI_WAYLAND_SUPPORT ON CACHE BOOL "" FORCE)
+    # Disable Linux-specific loader features
+    add_compile_definitions(LOADER_ENABLE_LINUX_SORT=0)
+endif()
