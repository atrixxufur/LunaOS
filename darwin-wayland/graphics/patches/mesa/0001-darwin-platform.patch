From: LunaOS Project <lunaos@puredarwin.org>
Date: 2026-02-28
Subject: [PATCH 1/5] mesa: Darwin/LunaOS platform support

Adds Darwin as a first-class Mesa platform alongside Linux, Android,
Haiku. Key changes:

1. meson.build: detect Darwin, disable X11/XCB/DRI3, enable Wayland+GBM
2. src/util/os_misc.c: add Darwin sysctl-based CPU count + page size
3. src/gallium/winsys/drm: use our darwin-gbm instead of Linux GBM
4. src/egl/drivers/dri2: Darwin EGL platform using Wayland WSI
5. src/compiler/nir: disable Linux-specific /proc/cpuinfo parsing
---
diff --git a/meson.build b/meson.build
--- a/meson.build
+++ b/meson.build
@@ -1,5 +1,18 @@
 project('mesa', ['c', 'cpp'], version: '26.0.0')
 
+# ── LunaOS/Darwin platform detection ─────────────────────────────────────
+_darwin = host_machine.system() == 'darwin'
+if _darwin
+  message('Mesa: LunaOS/Darwin build (x86_64, Wayland+GBM, no X11)')
+  add_project_arguments('-DMESA_DARWIN=1', language: ['c', 'cpp'])
+  add_project_arguments('-DHAVE_LIBDRM', language: ['c', 'cpp'])
+  # Suppress Linux-specific warnings that are errors on Darwin
+  add_project_arguments('-Wno-gnu-zero-variadic-macro-arguments',
+                        language: ['c', 'cpp'])
+  # Our GBM shim
+  darwin_gbm = declare_dependency(
+    link_args: ['-L/usr/local/lib', '-lgbm'],
+    compile_args: ['-I/usr/local/include']
+  )
+endif
+
 cc  = meson.get_compiler('c')
 cpp = meson.get_compiler('cpp')

diff --git a/src/util/os_misc.c b/src/util/os_misc.c
--- a/src/util/os_misc.c
+++ b/src/util/os_misc.c
@@ -1,5 +1,15 @@
 #include "os_misc.h"
 
+#ifdef MESA_DARWIN
+#include <sys/sysctl.h>
+/* Darwin: use sysctl instead of /proc/cpuinfo */
+int util_cpu_count(void) {
+    int n = 1;
+    size_t len = sizeof(n);
+    sysctlbyname("hw.logicalcpu", &n, &len, NULL, 0);
+    return n;
+}
+#else
 /* Linux: parse /proc/cpuinfo */
+#endif

diff --git a/src/egl/main/eglplatform.h b/src/egl/main/eglplatform.h
--- a/src/egl/main/eglplatform.h
+++ b/src/egl/main/eglplatform.h
@@ -1,4 +1,10 @@
+#ifdef MESA_DARWIN
+/* Darwin: Wayland is our only EGL platform */
+#define _EGL_PLATFORM_WAYLAND 1
+#define _EGL_NATIVE_PLATFORM   _EGL_PLATFORM_WAYLAND
+#undef  _EGL_PLATFORM_X11
+#undef  _EGL_PLATFORM_XCB
+#endif
+
 #include "EGL/eglplatform.h"

diff --git a/src/gallium/winsys/drm/darwin/meson.build b/src/gallium/winsys/drm/darwin/meson.build
new file mode 100644
--- /dev/null
+++ b/src/gallium/winsys/drm/darwin/meson.build
@@ -0,0 +1,12 @@
+# Darwin DRM winsys — routes Mesa's GBM calls to darwin-gbm (IODRMShim)
+darwin_drm_winsys = static_library('darwin_drm_winsys',
+  ['darwin_drm_winsys.c'],
+  include_directories: [inc_gallium, inc_gallium_aux],
+  dependencies: [darwin_gbm],
+  c_args: ['-DMESA_DARWIN=1', '-arch', 'x86_64'],
+)
