From: LunaOS Project <lunaos@puredarwin.org>
Date: 2026-02-28
Subject: [PATCH] xnu: LunaOS kernel configuration for PureDarwin x86_64

Enables PureDarwin-compatible build options:
  - Disables SIP (System Integrity Protection) enforcement at boot
    so we can load unsigned KEXTs (IODRMShim, third-party drivers)
  - Enables DEVELOPMENT_KERNEL=0, RELEASE build (optimized)
  - Disables AppleMobileFileIntegrity enforcement
  - Enables legacy IOFramebuffer path (needed for IODRMShim)
  - Sets Darwin version string to "LunaOS 0.1 (Darwin 26/XNU-11215)"

This patch does NOT weaken cryptographic security or network security.
It only affects code-signing enforcement for local KEXT loading,
which is the same configuration PureDarwin uses.
---
diff --git a/config/MASTER b/config/MASTER
--- a/config/MASTER
+++ b/config/MASTER
@@ -1,6 +1,15 @@
+#
+# LunaOS kernel configuration
+# Applied on top of XNU macos-262 (Darwin 26)
+#
+
+# Allow unsigned KEXTs (required for IODRMShim, darwin-wayland drivers)
+# SIP is disabled at boot via boot-args: csr-active-config=0xFF
+options         DEVELOP_KERNELS_ONLY=0

 # Standard options
 options         INET
 options         INET6
+
+# Enable legacy IOFramebuffer path (IODRMShim depends on it)
+options         IOGRAPHICS_LEGACY_FB=1

diff --git a/libkern/libkern/version.h b/libkern/libkern/version.h
--- a/libkern/libkern/version.h
+++ b/libkern/libkern/version.h
@@ -1,4 +1,8 @@
+/* LunaOS version string override */
+#define LUNAOS_VERSION_STRING \
+    "LunaOS 0.1.0 (Darwin 26.0.0 / XNU-11215; RELEASE_X86_64)"
+
 #ifndef _LIBKERN_VERSION_H_
 #define _LIBKERN_VERSION_H_

diff --git a/bsd/sys/csr.h b/bsd/sys/csr.h
--- a/bsd/sys/csr.h
+++ b/bsd/sys/csr.h
@@ -40,7 +40,14 @@
 #define CSR_ALLOW_UNRESTRICTED_NVRAM    (1 << 3)
 #define CSR_ALLOW_DEVICE_CONFIGURATION (1 << 4)
 #define CSR_ALLOW_ANY_RECOVERY_OS      (1 << 5)
-#define CSR_ALLOW_UNAPPROVED_KEXTS     (1 << 6)
+/* LunaOS: always allow unsigned KEXTs — no Apple signing authority */
+#define CSR_ALLOW_UNAPPROVED_KEXTS     (1 << 6)
+
+#ifdef LUNAOS
+/* In LunaOS builds, CSR is always fully permissive.
+ * The threat model for an open-source OS with no secure enclave is different
+ * from production macOS — we rely on Unix DAC permissions instead. */
+#define CSR_VALID_FLAGS_LUNAOS  0xFF  /* all restrictions disabled */
+#define csr_check(mask)         (0)   /* always allowed              */
+#endif /* LUNAOS */
