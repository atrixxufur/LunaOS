<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  IODRMShim.kext/Contents/Info.plist

  KEXT bundle descriptor.  IOKit uses this to:
    1. Match the KEXT against IOService providers in the registry
    2. Declare the C++ class hierarchy (OSBundleLibraries)
    3. Specify the IOKitPersonalities that trigger matching

  Matching strategy:
    We match on IOFramebuffer instances — one KEXT instance per display.
    The probe() override selects the first available IOFramebuffer if
    multiple are present (e.g. dual-monitor setups).

  Build & sign (PureDarwin — SIP disabled, debug-signed):
    codesign --sign "Darwin Development" --entitlements IODRMShim.entitlements \
             IODRMShim.kext

  Load:
    kextload /Library/Extensions/IODRMShim.kext
    kextstat | grep IODRMShim     # should show loaded

  Verify /dev/dri was created:
    ls -la /dev/dri/
    # crw-rw---- 1 root video  XX,0  card0
    # crw-rw-rw- 1 root video  XX,128 renderD128
-->
<plist version="1.0">
<dict>
    <key>CFBundleIdentifier</key>
    <string>org.puredarwin.driver.IODRMShim</string>

    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>

    <key>CFBundleName</key>
    <string>IODRMShim</string>

    <key>CFBundlePackageType</key>
    <string>KEXT</string>

    <key>CFBundleShortVersionString</key>
    <string>0.1.0</string>

    <key>CFBundleVersion</key>
    <string>1</string>

    <key>CFBundleExecutable</key>
    <string>IODRMShim</string>

    <key>CFBundleSignature</key>
    <string>????</string>

    <!-- IOKit personality: match on any IOFramebuffer provider -->
    <key>IOKitPersonalities</key>
    <dict>
        <key>IODRMShimPersonality</key>
        <dict>
            <!-- The C++ class in our KEXT that will be instantiated -->
            <key>IOClass</key>
            <string>IODRMShim</string>

            <!-- Match any IOFramebuffer provider -->
            <key>IOProviderClass</key>
            <string>IOFramebuffer</string>

            <!-- Probe score: run after Apple's built-in display drivers -->
            <key>IOProbeScore</key>
            <integer>100</integer>

            <!-- Our bundle identifier (must match CFBundleIdentifier) -->
            <key>CFBundleIdentifier</key>
            <string>org.puredarwin.driver.IODRMShim</string>

            <!--
              IOMatchCategory prevents multiple personalities from matching
              the same IOFramebuffer. Without this, we'd attach twice on
              dual-GPU Macs.
            -->
            <key>IOMatchCategory</key>
            <string>IODRMShim</string>
        </dict>

        <!--
          Second personality: match virtio-gpu specifically.
          virtio-gpu appears as a PCI device (class 0x030200) and registers
          an IOFramebuffer when the virtio-gpu kext is loaded.
          This personality gives us priority on QEMU virtual hardware.
        -->
        <key>IODRMShimVirtioPersonality</key>
        <dict>
            <key>IOClass</key>
            <string>IODRMShim</string>
            <key>IOProviderClass</key>
            <string>IOFramebuffer</string>
            <key>IOProbeScore</key>
            <integer>200</integer>
            <key>CFBundleIdentifier</key>
            <string>org.puredarwin.driver.IODRMShim</string>
            <key>IOMatchCategory</key>
            <string>IODRMShim</string>
            <!-- Only match devices with "virtio" in their IONameMatch -->
            <key>IONameMatch</key>
            <string>virtio-gpu</string>
        </dict>
    </dict>

    <!--
      OSBundleLibraries: declare which KPI (Kernel Programming Interface)
      libraries we use.  These must exactly match what's in the running
      kernel.  Version ranges allow minor updates without relinking.

      com.apple.kpi.iokit       — IOService, IOUserClient, IOWorkLoop, etc.
      com.apple.kpi.libkern     — OSArray, OSDictionary, OSSymbol, etc.
      com.apple.kpi.mach        — mach port / task APIs
      com.apple.kpi.bsd         — cdevsw, devfs_make_node, proc, etc.
      com.apple.kpi.unsupported — IOMemoryDescriptor kernel-only methods
                                  (getBytesNoCopy, getPhysicalAddress)
                                  Needed for VRAM access; accepted on
                                  PureDarwin where SIP is disabled.
    -->
    <key>OSBundleLibraries</key>
    <dict>
        <key>com.apple.kpi.iokit</key>
        <string>26.0</string>
        <key>com.apple.kpi.libkern</key>
        <string>26.0</string>
        <key>com.apple.kpi.mach</key>
        <string>26.0</string>
        <key>com.apple.kpi.bsd</key>
        <string>26.0</string>
        <key>com.apple.kpi.unsupported</key>
        <string>26.0</string>
    </dict>

    <!-- Allow loading on PureDarwin without Apple signature -->
    <key>OSBundleAllowUserLoad</key>
    <true/>

    <key>NSHumanReadableCopyright</key>
    <string>Copyright 2026 PureDarwin Project. Apache License 2.0.</string>

    <!--
      Architecture: x86_64 only.
      TODO_ARM64: Add arm64 slice + IOMobileFramebuffer personality here
      when arm64 backend is implemented.
    -->
    <key>OSBundleRequired</key>
    <string>Root</string>
</dict>
</plist>
