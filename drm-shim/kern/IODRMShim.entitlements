<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  IODRMShim.entitlements

  Entitlements for signing IODRMShim.kext on PureDarwin.
  On a production macOS system these would require an Apple-issued
  kernel extension certificate.  On PureDarwin with SIP disabled
  (csrutil disable), a self-signed certificate is sufficient.

  Required entitlements for our KEXT:
    com.apple.security.cs.allow-unsigned-executable-memory
      → allows our kernel code to execute without code-signing checks
        on each page (needed for JIT-style dispatch tables in cdevsw)

    com.apple.rootless.kext-management
      → signals that this KEXT participates in kext management
        (relevant when SIP is partially enabled)

  Sign command:
    # Create a self-signed cert first (once):
    security create-keychain -p "" darwin-dev.keychain
    security create-certificate -k darwin-dev.keychain \
        -t codeSign -s "Darwin Development"

    # Sign the KEXT:
    codesign --force --sign "Darwin Development" \
             --entitlements IODRMShim.entitlements \
             --timestamp=none \
             IODRMShim.kext

    # Verify:
    codesign -dv --entitlements :- IODRMShim.kext
-->
<plist version="1.0">
<dict>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <key>com.apple.rootless.kext-management</key>
    <true/>

    <!-- Required to open /dev/dri device nodes from kernel context -->
    <key>com.apple.security.device.camera</key>
    <false/>

    <!-- IOKit device matching entitlement -->
    <key>com.apple.security.iokit-user-client-class</key>
    <array>
        <string>IODRMShimUserClient</string>
    </array>
</dict>
</plist>
