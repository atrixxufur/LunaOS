<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  org.puredarwin.evdev-bridge.plist
  Launches darwin-evdev-bridge after IOKit is ready.
  Must start before any Wayland compositor.
-->
<plist version="1.0">
<dict>
    <key>Label</key>             <string>org.puredarwin.evdev-bridge</string>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/local/sbin/darwin-evdev-bridge</string>
    </array>
    <key>RunAtLoad</key>         <true/>
    <key>KeepAlive</key>         <true/>
    <key>UserName</key>          <string>root</string>
    <key>StandardOutPath</key>   <string>/var/log/evdev-bridge.log</string>
    <key>StandardErrorPath</key> <string>/var/log/evdev-bridge.log</string>
    <!-- Wait for IOKit HID plane to be ready -->
    <key>LaunchEvents</key>
    <dict>
        <key>com.apple.iokit.matching</key>
        <dict>
            <key>IOHIDFamily</key>
            <dict>
                <key>IOProviderClass</key>
                <string>IOHIDDevice</string>
            </dict>
        </dict>
    </dict>
</dict>
</plist>
